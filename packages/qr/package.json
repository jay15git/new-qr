{
  "name": "@new-qr/qr",
  "version": "0.1.0",
  "private": true,
  "description": "Customizable QR code, animated QR, and paper shader React components",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "vendor/bitjson-qr-code/dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts"
    },
    "./animated": {
      "types": "./src/animated/index.ts",
      "import": "./src/animated/index.ts"
    },
    "./shaders": {
      "types": "./src/shaders/index.ts",
      "import": "./src/shaders/index.ts"
    }
  },
  "dependencies": {
    "@paper-design/shaders": "0.0.76",
    "@paper-design/shaders-react": "0.0.76"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@paper-design/shaders": {
      "optional": true
    },
    "@paper-design/shaders-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
