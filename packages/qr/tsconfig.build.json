{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "incremental": false,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "../../bitjson-vendor/runtime.js": ["./src/bitjson-vendor/index.d.ts"],
      "../bitjson-vendor/runtime.js": ["./src/bitjson-vendor/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vendor/react-qr-code/**/*.ts", "vendor/react-qr-code/**/*.tsx"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "vendor/bitjson-qr-code/**"]
}
