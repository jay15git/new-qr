{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": [
    "app/**/*.{js,jsx,ts,tsx,css}",
    "components/**/*.{js,jsx,ts,tsx,css}",
    "hooks/**/*.{js,jsx,ts,tsx}",
    "lib/**/*.{js,jsx,ts,tsx}",
    "*.{js,mjs,cjs,ts,mts,cts}"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "tags": [
    "-lintignore"
  ]
}
