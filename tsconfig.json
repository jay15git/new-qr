{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@new-qr/qr": ["./packages/qr/src/index.ts"],
      "@new-qr/qr/react": ["./packages/qr/src/react/index.ts"],
      "@new-qr/qr/shaders": ["./packages/qr/src/shaders/index.ts"],
      "@new-qr/qr/animated": ["./packages/qr/src/animated/index.ts"],
      "@new-qr/qr-internal/codegen": ["./packages/qr/src/scene/codegen/index.ts"],
      "@new-qr/qr-internal/export": ["./packages/qr/src/scene/export/index.ts"],
      "@new-qr/qr-internal/scene": ["./packages/qr/src/scene/index.ts"],
      "@new-qr/qr-internal/core": ["./packages/qr/src/core/index.ts"],
      "@new-qr/qr-internal/react-qr-code": ["./packages/qr/src/react-qr-code/index.ts"],
      "@new-qr/qr-internal/bitjson-vendor": ["./packages/qr/src/bitjson-vendor/runtime.js"],
      "@new-qr/qr-internal/web-component": ["./packages/qr/src/web-component/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "packages/qr/vendor"]
}
