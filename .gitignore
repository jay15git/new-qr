# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
.cache/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# hidden nested app copy
/.portable-compose-editor/
/.external/

# generated visual artifacts
/.codex-screenshots/
/designs/image-import*.png
/designs/image-import*.jpg

# cursor IDE local artifacts (keep shared rules/hooks/mcp in repo)
.cursor/*
!.cursor/rules/
!.cursor/hooks/
!.cursor/hooks.json
!.cursor/mcp.json

# CocoIndex Code (ccc)
/.cocoindex_code/
